.container { padding: 0 0 60rpx; }

.header {
  background: linear-gradient(135deg, #4F7EFF, #7B6FF0);
  padding: 60rpx 40rpx;
  display: flex;
  gap: 30rpx;
  color: #fff;
}
.bank-icon { font-size: 80rpx; }
.header-info { flex: 1; }
.bank-name { font-size: 38rpx; font-weight: 700; margin-bottom: 10rpx; }
.bank-desc { font-size: 26rpx; opacity: 0.85; margin-bottom: 16rpx; }
.bank-meta { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; opacity: 0.9; }
.meta-sep { opacity: 0.6; }
.meta-item.tag { background: rgba(255,255,255,0.25); padding: 4rpx 16rpx; border-radius: 20rpx; }

/* 进度卡片 */
.progress-card { margin: 24rpx 30rpx; border-radius: 20rpx; }
.progress-title { font-size: 28rpx; font-weight: 600; margin-bottom: 20rpx; }
.progress-stats { display: flex; justify-content: space-around; margin-bottom: 20rpx; }
.pstat { text-align: center; }
.pstat-num { display: block; font-size: 44rpx; font-weight: 700; color: #333; }
.pstat-num.green { color: var(--color-success); }
.pstat-num.blue  { color: var(--color-primary); }
.pstat-label { font-size: 22rpx; color: #999; }
.pbar-wrap { display: flex; align-items: center; gap: 16rpx; }
.pbar { flex: 1; height: 12rpx; background: #EEE; border-radius: 6rpx; overflow: hidden; }
.pbar-fill { height: 100%; background: var(--color-primary); border-radius: 6rpx; transition: width 0.4s; }
.pbar-label { font-size: 22rpx; color: #999; white-space: nowrap; }

.section-title { font-size: 30rpx; font-weight: 700; padding: 30rpx 30rpx 16rpx; color: #333; }

/* 练习模式 */
.modes { padding: 0 30rpx; display: flex; flex-direction: column; gap: 16rpx; }
.mode-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: var(--shadow);
}
.mode-icon { font-size: 52rpx; }
.mode-name { font-size: 32rpx; font-weight: 600; }
.mode-desc { font-size: 24rpx; color: #999; flex: 1; }
.mode-arrow { font-size: 40rpx; color: #CCC; }

/* 标签网格 */
.tags-grid { padding: 0 30rpx; display: flex; flex-wrap: wrap; gap: 16rpx; }
.tag-item {
  background: var(--color-primary-light);
  color: var(--color-primary);
  padding: 14rpx 28rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.loading-page { display: flex; justify-content: center; align-items: center; min-height: 60vh; }
.loading-dot { width: 60rpx; height: 60rpx; border: 6rpx solid var(--color-primary); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; }
@keyframes spin { to { transform: rotate(360deg); } }
