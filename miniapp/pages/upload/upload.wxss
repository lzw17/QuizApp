.container { padding: 24rpx 30rpx 160rpx; }
.section { margin-bottom: 24rpx; border-radius: 20rpx; }
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 28rpx; color: #333; }

.form-item { margin-bottom: 24rpx; }
.form-item.row { display: flex; align-items: center; justify-content: space-between; }
.form-label { font-size: 28rpx; color: #555; display: block; margin-bottom: 12rpx; }
.required { color: #FF4D4F; }
.form-input {
  width: 100%;
  background: #F8F9FB;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  outline: none;
}
.form-textarea {
  width: 100%;
  background: #F8F9FB;
  border-radius: 12rpx;
  padding: 22rpx 24rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  outline: none;
}

/* 出题数量控制 */
.num-control { display: flex; align-items: center; gap: 24rpx; }
.num-btn {
  width: 60rpx;
  height: 60rpx;
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
}
.num-val {  color: #333; min-width: 40rpx; text-align: center; }

/* 来源选择 */
.source-tabs { display: flex; gap: 16rpx; margin-bottom: 28rpx; }
.source-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #F8F9FB;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.source-tab-icon { width: 36rpx; height: 36rpx; }
.source-tab.active { background: var(--color-primary-light); color: var(--color-primary); border-color: var(--color-primary); }

/* 上传区域 */
.upload-zone {
  border: 3rpx dashed #CCCCCC;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.upload-icon { font-size: 80rpx; }
.upload-icon-img { width: 80rpx; height: 80rpx; }
.upload-tip { font-size: 30rpx; color: #555; font-weight: 600; }
.upload-sub { font-size: 24rpx; color: #999; }

.file-selected {
  display: flex;
  align-items: center;
  background: #F0F4FF;
  border-radius: 16rpx;
  padding: 24rpx;
  gap: 20rpx;
}
.file-icon { font-size: 60rpx; }
.file-info { flex: 1; overflow: hidden; }
.file-name { display: block; font-size: 28rpx; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.file-size { display: block; font-size: 24rpx; color: #999; margin-top: 6rpx; }
.file-remove { font-size: 36rpx; color: #999; padding: 10rpx; }

.url-input { margin-top: 0; }

/* 提交区 */
.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}
.submit-btn { width: 100%; }
