.container { padding-bottom: 60rpx; background: #F5F6FA; }

/* 分数区 */
.score-section { padding: 80rpx 40rpx 50rpx; display: flex; flex-direction: column; align-items: center; }
.score-section.pass { background: linear-gradient(135deg, #18C971, #56E29A); }
.score-section.fail { background: linear-gradient(135deg, #FF4D4F, #FF7875); }
.score-ring {
  width: 240rpx; height: 240rpx; border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  border: 8rpx solid rgba(255,255,255,0.6); margin-bottom: 32rpx;
}
.score-num { font-size: 96rpx; font-weight: 900; color: #fff; line-height: 1; }
.score-unit { font-size: 28rpx; color: rgba(255,255,255,0.8); }
.pass-label { font-size: 36rpx; color: #fff; font-weight: 700; margin-bottom: 40rpx; }
.score-stats { display: flex; gap: 80rpx; }
.sstat { text-align: center; }
.sstat-num { display: block; font-size: 52rpx; font-weight: 700; color: #fff; }
.sstat-label { font-size: 22rpx; color: rgba(255,255,255,0.8); }

/* 操作按钮 */
.action-row { display: flex; gap: 20rpx; padding: 30rpx; }
.action-btn { flex: 1; }

.section-title { font-size: 30rpx; font-weight: 700; padding: 20rpx 30rpx 10rpx; }

/* 错题列表 */
.wrong-list { padding: 0 24rpx; display: flex; flex-direction: column; gap: 20rpx; }
.wrong-item { border-radius: 20rpx; }
.wi-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.wi-num { font-size: 24rpx; color: #888; }
.wi-type { font-size: 22rpx; padding: 4rpx 14rpx; border-radius: 16rpx; }
.q-type-tag.single { background: #E8F0FF; color: #4F7EFF; }
.q-type-tag.multi  { background: #FFF3E0; color: #F57C00; }
.q-type-tag.judge  { background: #E8F8EF; color: #18C971; }
.wi-content { font-size: 30rpx; line-height: 1.7; color: #222; margin-bottom: 20rpx; font-weight: 500; }
.wi-answers { background: #F8F9FB; border-radius: 12rpx; padding: 20rpx; margin-bottom: 16rpx; }
.wi-row { display: flex; align-items: center; gap: 8rpx; margin-bottom: 8rpx; }
.wi-row:last-child { margin-bottom: 0; }
.wi-label { font-size: 26rpx; color: #666; }
.wi-ans { font-size: 26rpx; font-weight: 700; }
.wi-ans.red { color: var(--color-danger); }
.wi-ans.green { color: var(--color-success); }
.wi-exp { font-size: 26rpx; color: #555; line-height: 1.8; padding: 16rpx; background: #FFFDF0; border-radius: 12rpx; border-left: 6rpx solid #FAAD14; }
.exp-label { font-weight: 600; color: #F57C00; }
