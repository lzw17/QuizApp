.container { display: flex; flex-direction: column; min-height: 100vh; background: #F5F6FA; }

/* 顶栏 */
.top-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #F0F0F0;
  gap: 16rpx;
}
.progress-info { display: flex; align-items: baseline; gap: 4rpx; }
.q-index { font-size: 40rpx; font-weight: 700; color: #4F7EFF; }
.q-sep, .q-total { font-size: 26rpx; color: #999; }
.mode-tag { font-size: 22rpx; }
.star-btn { margin-left: auto; font-size: 52rpx; color: #FAAD14; padding: 0 10rpx; }

/* 整体进度条 */
.q-progress-bar { height: 6rpx; background: #EEE; }
.q-progress-fill { height: 100%; background: var(--color-primary); transition: width 0.3s; }

/* 题目卡片 */
.question-card { flex: 1; margin: 24rpx 24rpx 180rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: var(--shadow); }

.q-meta { display: flex; align-items: center; flex-wrap: wrap; gap: 12rpx; margin-bottom: 24rpx; }
.q-type-tag { padding: 6rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 600; }
.q-type-tag.single { background: #E8F0FF; color: #4F7EFF; }
.q-type-tag.multi  { background: #FFF3E0; color: #F57C00; }
.q-type-tag.judge  { background: #E8F8EF; color: #18C971; }
.q-difficulty { display: flex; gap: 6rpx; align-items: center; }
.q-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.q-tag { background: #F5F6FA; color: #888; font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx; }

.q-content { font-size: 32rpx; line-height: 1.7; color: #222; margin-bottom: 36rpx; font-weight: 500; }

/* 选项 */
.options { display: flex; flex-direction: column; gap: 16rpx; }
.option {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #EEEEEE;
  background: #FAFAFA;
  transition: all 0.2s;
}
.option.selected { border-color: #4F7EFF; background: #EEF2FF; }
.option.correct  { border-color: #18C971; background: #E8F8EF; }
.option.wrong    { border-color: #FF4D4F; background: #FFF1F1; }
.option-key {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #E8E8E8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
  flex-shrink: 0;
  margin-right: 18rpx;
}
.option.selected .option-key { background: #4F7EFF; color: #fff; }
.option.correct .option-key  { background: #18C971; color: #fff; }
.option.wrong .option-key    { background: #FF4D4F; color: #fff; }
.option-text { flex: 1; font-size: 28rpx; line-height: 1.6; color: #333; padding-top: 6rpx; }
.option-icon { font-size: 32rpx; margin-left: 12rpx; }
.option.correct .option-icon { color: #18C971; }
.option.wrong .option-icon   { color: #FF4D4F; }

/* 解析 */
.explanation { margin-top: 32rpx; padding: 24rpx; background: #FFFDF0; border-radius: 16rpx; border-left: 6rpx solid #FAAD14; }
.exp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.exp-result { font-size: 28rpx; font-weight: 700; }
.exp-result.correct { color: var(--color-success); }
.exp-result.wrong   { color: var(--color-danger); }
.exp-rate { font-size: 22rpx; color: #999; }
.exp-content { font-size: 26rpx; color: #555; line-height: 1.8; }
.exp-label { font-weight: 600; color: #F57C00; }

/* 底部按钮 */
.bottom-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
}
.btn-prev {
  width: 88rpx; height: 88rpx; border-radius: 50%; background: #F0F4FF; color: #4F7EFF;
  font-size: 44rpx; display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; border: none;
}
.btn-prev::after { border: none; }
.confirm-btn, .next-btn { flex: 1; }

/* 加载 */
.loading-page {
  display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh;
}
.loading-dot {
  width: 80rpx; height: 80rpx; border: 6rpx solid #4F7EFF; border-top-color: transparent;
  border-radius: 50%; animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* 完成页 */
.done-page { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60rpx; }
.done-emoji { font-size: 120rpx; margin-bottom: 24rpx; }
.done-title { font-size: 44rpx; font-weight: 700; margin-bottom: 40rpx; }
.done-stats { display: flex; gap: 60rpx; margin-bottom: 60rpx; }
.dstat { text-align: center; }
.dstat-num { display: block; font-size: 56rpx; font-weight: 700; color: #4F7EFF; }
.dstat-num.green { color: var(--color-success); }
.dstat-label { font-size: 24rpx; color: #999; }
.done-btns { display: flex; gap: 24rpx; }
