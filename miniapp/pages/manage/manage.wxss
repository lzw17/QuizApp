.container { padding: 24rpx; background: #F5F6FA; min-height: 100vh; }
.section-title { font-size: 32rpx; font-weight: 700; margin-bottom: 20rpx; }

.bank-list { display: flex; flex-direction: column; gap: 16rpx; }
.bank-item { display: flex; align-items: center; justify-content: space-between; border-radius: 16rpx; }
.bi-info { flex: 1; }
.bi-name { font-size: 30rpx; font-weight: 600; margin-bottom: 10rpx; }
.bi-meta { display: flex; align-items: center; gap: 16rpx; }
.bi-count { font-size: 24rpx; color: #888; }
.bi-status { font-size: 22rpx; }
.bi-status.ready    { background: #E8F8EF; color: #18C971; }
.bi-status.pending  { background: #FFF7E0; color: #FAAD14; }
.bi-status.reviewing{ background: #EEF2FF; color: #4F7EFF; }
.bi-actions { display: flex; gap: 12rpx; }
.action-btn { padding: 10rpx 20rpx; border-radius: 10rpx; font-size: 24rpx; }
.edit-btn { background: #EEF2FF; color: #4F7EFF; }
.del-btn  { background: #FFF1F1; color: #FF4D4F; }

/* 弹层 */
.modal-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; }
.modal {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 32rpx 32rpx 0 0;
  height: 75vh; display: flex; flex-direction: column;
  transform: translateY(100%); transition: transform 0.3s ease; z-index: 101;
}
.modal.show { transform: translateY(0); }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx 30rpx 20rpx; border-bottom: 2rpx solid #EEE; }
.modal-title { font-size: 34rpx; font-weight: 700; }
.modal-close { font-size: 40rpx; color: #888; padding: 10rpx; }
.modal-scroll { flex: 1; }

.q-edit-item { padding: 24rpx 30rpx; border-bottom: 2rpx solid #F0F0F0; }
.qe-type { margin-bottom: 12rpx; }
.qe-content { font-size: 28rpx; line-height: 1.6; margin-bottom: 12rpx; }
.qe-answer { font-size: 24rpx; color: #666; margin-bottom: 12rpx; }
.ans-text { font-weight: 700; color: var(--color-success); }
.qe-actions { display: flex; gap: 16rpx; }
.qe-btn { padding: 10rpx 24rpx; background: #F0F0F0; border-radius: 10rpx; font-size: 24rpx; }
.qe-btn.danger { background: #FFF1F1; color: #FF4D4F; }

/* 编辑表单 */
.form-modal {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: flex-end; z-index: 200;
}
.fm-header { display: flex; justify-content: space-between; align-items: center; padding: 30rpx; border-bottom: 2rpx solid #EEE; font-size: 34rpx; font-weight: 700; }
.fm-body { background: #fff; border-radius: 32rpx 32rpx 0 0; width: 100%; padding: 0 30rpx 40rpx; }
.fm-item { margin-bottom: 24rpx; }
.fm-label { display: block; font-size: 26rpx; color: #555; margin-bottom: 10rpx; }
.fm-input, .fm-textarea {
  width: 100%; background: #F8F9FB; border-radius: 12rpx;
  padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box;
}
.fm-textarea { min-height: 120rpx; }
