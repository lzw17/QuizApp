/* 考前准备页 */
.prepare-page {
  display: flex; flex-direction: column; align-items: center;
  padding: 80rpx 40rpx; min-height: 100vh; background: #F5F6FA;
}
.prepare-icon { font-size: 120rpx; margin-bottom: 24rpx; }
.prepare-title { font-size: 48rpx; font-weight: 700; margin-bottom: 8rpx; }
.prepare-bank { font-size: 26rpx; color: #888; margin-bottom: 48rpx; }
.prepare-rules { width: 100%; max-width: 600rpx; margin-bottom: 32rpx; border-radius: 20rpx; }
.rule-item { display: flex; justify-content: space-between; padding: 18rpx 0; border-bottom: 2rpx solid #F0F0F0; }
.rule-item:last-child { border-bottom: none; }
.rule-label { font-size: 28rpx; color: #555; }
.rule-val { font-size: 28rpx; font-weight: 600; color: #333; }
.count-setting { display: flex; align-items: center; justify-content: space-between; width: 100%; max-width: 600rpx; margin-bottom: 48rpx; background: #fff; padding: 24rpx 30rpx; border-radius: 16rpx; }
.cs-label { font-size: 30rpx; }
.num-control { display: flex; align-items: center; gap: 28rpx; }
.num-btn { width: 64rpx; height: 64rpx; background: var(--color-primary-light); color: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; font-weight: 700; }
.num-val { font-size: 40rpx; font-weight: 700; min-width: 60rpx; text-align: center; }
.start-btn { width: 560rpx; }

/* 考试页 */
.exam-page { display: flex; flex-direction: column; min-height: 100vh; background: #F5F6FA; }
.exam-header { display: flex; align-items: center; padding: 20rpx 30rpx; background: #fff; border-bottom: 2rpx solid #F0F0F0; gap: 20rpx; }
.timer { font-size: 36rpx; font-weight: 700; color: #333; background: #F0F4FF; padding: 8rpx 20rpx; border-radius: 12rpx; }
.timer.urgent { color: #FF4D4F; background: #FFF1F1; animation: blink 1s step-start infinite; }
@keyframes blink { 50% { opacity: 0.4; } }
.exam-progress { font-size: 26rpx; color: #888; flex: 1; }
.sheet-btn { font-size: 26rpx; color: #4F7EFF; font-weight: 600; padding: 10rpx 20rpx; background: #EEF2FF; border-radius: 10rpx; }

/* 题目区（复用 practice 样式，减少重复） */
.question-card { flex: 1; margin: 24rpx 24rpx 160rpx; background: #fff; border-radius: 24rpx; padding: 36rpx; box-shadow: var(--shadow); }
.q-num { font-size: 26rpx; color: #888; margin-bottom: 8rpx; }
.q-type-tag { display: inline-block; padding: 6rpx 18rpx; border-radius: 20rpx; font-size: 22rpx; font-weight: 600; margin-bottom: 20rpx; }
.q-type-tag.single { background: #E8F0FF; color: #4F7EFF; }
.q-type-tag.multi  { background: #FFF3E0; color: #F57C00; }
.q-type-tag.judge  { background: #E8F8EF; color: #18C971; }
.q-content { font-size: 32rpx; line-height: 1.7; color: #222; margin-bottom: 32rpx; font-weight: 500; }
.options { display: flex; flex-direction: column; gap: 16rpx; }
.option { display: flex; align-items: center; padding: 24rpx; border-radius: 16rpx; border: 2rpx solid #EEE; background: #FAFAFA; }
.option.selected { border-color: #4F7EFF; background: #EEF2FF; }
.option-key { width: 52rpx; height: 52rpx; border-radius: 50%; background: #E8E8E8; display: flex; align-items: center; justify-content: center; font-size: 26rpx; font-weight: 700; flex-shrink: 0; margin-right: 18rpx; }
.option.selected .option-key { background: #4F7EFF; color: #fff; }
.option-text { font-size: 28rpx; line-height: 1.6; color: #333; }

/* 底部导航 */
.exam-nav { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 16rpx 20rpx; display: flex; gap: 16rpx; box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08); }
.nav-btn { flex: 1; height: 84rpx; line-height: 84rpx; border-radius: 50rpx; font-size: 28rpx; background: #F0F4FF; color: #4F7EFF; border: none; }
.nav-btn::after { border: none; }
.nav-btn.submit-btn { background: var(--color-danger); color: #fff; }

/* 答题卡 */
.sheet-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 100; }
.sheet-panel {
  position: fixed; bottom: 0; left: 0; right: 0; background: #fff;
  border-radius: 32rpx 32rpx 0 0; padding: 32rpx 30rpx;
  transform: translateY(100%); transition: transform 0.3s ease;
  z-index: 101; max-height: 75vh; overflow-y: auto;
}
.sheet-panel.show { transform: translateY(0); }
.sheet-title { font-size: 34rpx; font-weight: 700; margin-bottom: 24rpx; }
.sheet-grid { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; }
.sheet-item {
  width: 88rpx; height: 88rpx; border-radius: 16rpx; background: #F0F0F0;
  display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #888;
}
.sheet-item.answered { background: var(--color-primary); color: #fff; }
.sheet-item.current  { background: #FAAD14; color: #fff; }
.sheet-legend { display: flex; gap: 30rpx; margin-bottom: 24rpx; }
.legend-item { display: flex; align-items: center; gap: 10rpx; font-size: 24rpx; color: #666; }
.legend-dot { width: 28rpx; height: 28rpx; border-radius: 8rpx; background: #F0F0F0; }
.legend-dot.answered { background: var(--color-primary); }
.legend-dot.current  { background: #FAAD14; }
.sheet-submit { width: 100%; }
