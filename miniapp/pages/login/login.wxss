page {
  background: #4F7EFF;
}

.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(160deg, #4F7EFF 0%, #6a3de8 100%);
}

/* ---- Hero 顶部 ---- */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0 72rpx;
  flex: 1;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.18);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-img {
  width: 96rpx;
  height: 96rpx;
}

.app-name {
  font-size: 60rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 6rpx;
  margin-bottom: 14rpx;
}

.app-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.78);
}

/* ---- 底部白卡 ---- */
.card {
  background: #fff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 52rpx 48rpx 64rpx;
}

.card-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a2e;
  text-align: center;
  margin-bottom: 44rpx;
}

/* ---- 头像 ---- */
.avatar-btn {
  width: 160rpx;
  height: 160rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border-radius: 50%;
  line-height: 1;
  position: relative;
}

.avatar-btn::after {
  border: none;
}

.avatar-row {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 44rpx;
}

.avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 16rpx;
}

.avatar-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #e8eeff;
}

.avatar-empty {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #eef1ff, #dce3ff);
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-emoji {
  font-size: 68rpx;
}

.avatar-badge {
  position: absolute;
  bottom: 4rpx;
  right: 4rpx;
  width: 48rpx;
  height: 48rpx;
  background: #4F7EFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}

.badge-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
  margin-top: -2rpx;
}

.avatar-label {
  font-size: 24rpx;
  color: #aab;
}

/* ---- 输入框 ---- */
.field {
  margin-bottom: 44rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 14rpx;
}

.field-input {
  width: 100%;
  background: #f6f7ff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  font-size: 32rpx;
  color: #222;
  box-sizing: border-box;
  border: 2rpx solid #eaecff;
}

.field-placeholder {
  color: #c0c4d6;
  font-size: 30rpx;
}

/* ---- 提交按钮 ---- */
.btn-submit {
  width: 100%;
  background: linear-gradient(135deg, #4F7EFF 0%, #6a3de8 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 32rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  box-shadow: 0 12rpx 36rpx rgba(79,126,255,0.38);
}

.btn-submit::after {
  border: none;
}

.btn-submit.loading {
  opacity: 0.65;
}

/* ---- 跳过 ---- */
.skip {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  padding: 8rpx 0;
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 10rpx;
  padding-left: 4rpx;
}

/* ---- 功能列表（登录阶段） ---- */
.feature-list {
  margin: 8rpx 0 48rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f3f4ff;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 44rpx;
  width: 56rpx;
  text-align: center;
}

.feature-text {
  font-size: 30rpx;
  color: #444;
}

/* ---- 微信登录按钮 ---- */
.btn-wx-login {
  width: 100%;
  background: #07C160;
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 32rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(7,193,96,0.35);
}

.btn-wx-login::after {
  border: none;
}

.btn-wx-login.loading {
  opacity: 0.65;
}

.wx-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.wx-dot {
  font-size: 36rpx;
  color: #fff;
}

/* ---- 隐私提示 ---- */
.privacy-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #ccc;
  padding: 4rpx 0;
}
