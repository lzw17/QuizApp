# 应用配置
APP_NAME=QuizApp
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production
DEBUG=true

# 微信小程序登录（生产环境必须配置 APPID/SECRET，并保持 MOCK=false）
WX_APPID=your-wechat-mini-program-appid
WX_SECRET=your-wechat-mini-program-secret
WX_MOCK_LOGIN=false
WX_MOCK_OPENID=local-dev-user
WX_MOCK_ADMIN=false
# 管理员 OpenID，多个值用英文逗号分隔（仅保存在后端）
ADMIN_OPENIDS=
AUTH_TOKEN_EXPIRE_DAYS=30

# 数据库配置：本地开发默认使用 SQLite
DATABASE_URL=sqlite:///./quiz_app.db
# 生产环境使用 MySQL 时替换为类似下面的连接地址
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/quiz_app

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# DeepSeek API
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# MinerU 文档解析 API（可选，有则用，无则降级到 PyPDF）
MINERU_API_KEY=your-mineru-api-key
MINERU_API_URL=https://mineru.net/api/v4

# 腾讯云 COS 文件存储（可选）
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
COS_REGION=ap-guangzhou
COS_BUCKET=quiz-app-bucket

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS 跨域（微信小程序域名）
ALLOWED_ORIGINS=*
